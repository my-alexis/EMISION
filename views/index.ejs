    <!-- Toast -->
    <div class="position-fixed top-0 end-0 p-3" style="z-index:2000">
        <div id="toastMsg" class="toast align-items-center text-white border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="toastBody"></div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ══════════════════════════════════════════════════
        //  NAVEGACIÓN
        // ══════════════════════════════════════════════════
        function showPage(pageId, linkEl) {
            document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nh-navbar .nav-link').forEach(l => l.classList.remove('active'));
            document.getElementById('page-' + pageId).classList.add('active');
            if (linkEl) linkEl.classList.add('active');
        }

        // ══════════════════════════════════════════════════
        //  CERTIFICACIONES (código original)
        // ══════════════════════════════════════════════════
        const CURSO_DATA = {
            cursoNombre: "<%= cursoNombre %>",
            docenteNombre: "<%= docenteNombre %>",
            fechaInicio: "<%= fechaInicio %>",
            fechaFin: "<%= fechaFin %>",
            horasAcademicas: "<%= horasAcademicas %>",
            horasCronologicas: "<%= horasCronologicas %>"
        };

        let FIRMA_BASE64 = "";

        document.querySelectorAll('input[name="tipoHoras"]').forEach(radio => {
            radio.addEventListener('change', () => {
                const esAcademicas = document.getElementById('horasAcademicasRadio').checked;
                const horas = esAcademicas ? CURSO_DATA.horasAcademicas : CURSO_DATA.horasCronologicas;
                const tipo = esAcademicas ? 'académicas' : 'cronológicas';
                document.getElementById('textoHorasSeleccionadas').textContent = `${horas} horas ${tipo}`;
            });
        });

        function getCreditosSeleccionados() {
            const esAcademicas = document.getElementById('horasAcademicasRadio').checked;
            return esAcademicas ? CURSO_DATA.horasAcademicas : CURSO_DATA.horasCronologicas;
        }

        function getTipoHorasLabel() {
            return document.getElementById('horasAcademicasRadio').checked ? 'académicas' : 'cronológicas';
        }

        document.querySelectorAll('input[name="tipoDoc"]').forEach(radio => {
            radio.addEventListener('change', () => {
                const esCertificado = document.getElementById('tipoCertificado').checked;
                document.getElementById('seccionFirma').style.display = esCertificado ? 'block' : 'none';
                document.getElementById('notaConstancia').classList.toggle('d-none', esCertificado);
                const badge = document.getElementById('tipoBadge');
                if (esCertificado) {
                    badge.textContent = 'CERTIFICADO';
                    badge.className = 'badge tipo-badge-certificado rounded-pill px-3';
                } else {
                    badge.textContent = 'CONSTANCIA';
                    badge.className = 'badge tipo-badge-constancia rounded-pill px-3';
                }
            });
        });

        function getTipoDocumento() {
            return document.querySelector('input[name="tipoDoc"]:checked').value;
        }

        function previsualizarFirma(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    FIRMA_BASE64 = e.target.result;
                    document.getElementById('imgPreview').src = e.target.result;
                    document.getElementById('imgPreview').style.display = 'block';
                    document.getElementById('previewText').style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function toggleFirmaVisibilidad() {
            const isChecked = document.getElementById('switchIncluirFirma').checked;
            document.getElementById('previewBoxFirma').style.opacity = isChecked ? "1" : "0.3";
            mostrarToast(isChecked ? "Firma del docente habilitada" : "Se eliminará al instructor del certificado",
                isChecked ? "info" : "warning");
        }

        // ── TEMARIO (sección Matrix) ──────────────────────────
        let TEMARIO_BASE64 = null;

        function toggleTemarioVisibilidad() {
            const on = document.getElementById('switchIncluirTemario').checked;
            document.getElementById('temarioInputArea').style.display = on ? 'block' : 'none';
            if (!on) { TEMARIO_BASE64 = null; document.getElementById('temarioPreview').style.display = 'none'; }
        }

        function cargarTemario(input) {
            const file = input.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = async e => {
                TEMARIO_BASE64 = e.target.result;
                document.getElementById('temarioNombre').textContent = file.name;
                // Contar páginas con pdf-lib en cliente (usa PDF.js desde CDN)
                try {
                    const arrayBuf = await file.arrayBuffer();
                    const { PDFDocument } = await import('https://cdn.jsdelivr.net/npm/pdf-lib@1.17.1/+esm');
                    const doc = await PDFDocument.load(arrayBuf);
                    document.getElementById('temarioPaginas').textContent = `${doc.getPageCount()} página(s)`;
                } catch (_) {
                    document.getElementById('temarioPaginas').textContent = `${(file.size / 1024).toFixed(1)} KB`;
                }
                document.getElementById('temarioPreview').style.display = 'flex';
                mostrarToast('Temario cargado correctamente', 'success');
            };
            reader.readAsDataURL(file);
        }

        function quitarTemario() {
            TEMARIO_BASE64 = null;
            document.getElementById('inputTemario').value = '';
            document.getElementById('temarioPreview').style.display = 'none';
            mostrarToast('Temario eliminado', 'info');
        }

        async function descargarPDF(datos, fila) {
            setBadge(fila, 'procesando');
            const tipo = getTipoDocumento();
            const incluirFirma = document.getElementById('switchIncluirFirma').checked;
            const firmaAEnviar = (tipo === 'certificado' && incluirFirma) ? FIRMA_BASE64 : "";
            const incluirQR = document.getElementById('checkQR').checked;
            const payload = {
                ...datos,
                creditos: getCreditosSeleccionados(),
                tipoHoras: getTipoHorasLabel(),
                firmaManual: firmaAEnviar,
                tipo,
                fechaEmision: getFechaEmision(),
                incluirQR: incluirQR,
                temarioPDF: TEMARIO_BASE64 || null
            };
            const endpoint = tipo === 'constancia' ? '/api/generar-pdf-individual-constancia' : '/api/generar-pdf-individual';
            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                if (!res.ok) throw new Error(await res.text());
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                const prefijo = tipo === 'constancia' ? 'Constancia' : 'Certificado';
                a.download = `${prefijo}_${datos.nombre.replace(/ /g, '_')}.pdf`;
                document.body.appendChild(a); a.click(); a.remove();
                URL.revokeObjectURL(url);
                setBadge(fila, 'ok');
            } catch (e) {
                setBadge(fila, 'error');
                mostrarToast('Error: ' + e.message, 'danger');
            }
        }

        function toggleAll(src) {
            document.querySelectorAll('.alumno-check').forEach(c => {
                c.checked = src.checked;
                c.closest('tr').classList.toggle('table-selected', src.checked);
            });
            actualizarContador();
        }

        function actualizarContador() {
            const n = document.querySelectorAll('.alumno-check:checked').length;
            document.getElementById('contadorSeleccionados').textContent = `${n} seleccionados`;
        }

        function descargarUno(btn) {
            const fila = btn.closest('tr');
            const check = fila.querySelector('.alumno-check');
            const datos = {
                nombre: check.dataset.nombre,
                codigo: check.dataset.codigo,
                curso: CURSO_DATA.cursoNombre,
                docente: CURSO_DATA.docenteNombre,
                inicio: CURSO_DATA.fechaInicio,
                fin: CURSO_DATA.fechaFin
            };
            descargarPDF(datos, fila);
        }

        async function certificarSeleccionados() {
            const checks = document.querySelectorAll('.alumno-check:checked');
            if (checks.length === 0) { mostrarToast('Selecciona al menos un alumno.', 'warning'); return; }
            const tipo = getTipoDocumento();
            const label = tipo === 'constancia' ? 'constancia(s)' : 'certificado(s)';
            if (!confirm(`¿Generar ${checks.length} ${label}?`)) return;
            for (const check of checks) {
                const fila = check.closest('tr');
                const datos = {
                    nombre: check.dataset.nombre,
                    codigo: check.dataset.codigo,
                    curso: CURSO_DATA.cursoNombre,
                    docente: CURSO_DATA.docenteNombre,
                    inicio: CURSO_DATA.fechaInicio,
                    fin: CURSO_DATA.fechaFin
                };
                await descargarPDF(datos, fila);
            }
        }

        function habilitarEdicionCurso() {
            document.getElementById('displayCursoNombre').classList.add('d-none');
            document.getElementById('btnEditarCurso').classList.add('d-none');
            document.getElementById('inputEditCurso').classList.remove('d-none');
            document.getElementById('btnGuardarCurso').classList.remove('d-none');
            document.getElementById('inputEditCurso').focus();
        }

        function guardarEdicionCurso() {
            const nuevoNombre = document.getElementById('inputEditCurso').value;
            CURSO_DATA.cursoNombre = nuevoNombre;
            document.getElementById('displayCursoNombre').innerHTML = `<i class="bi bi-mortarboard-fill me-2"></i>${nuevoNombre}`;
            document.getElementById('displayCursoNombre').classList.remove('d-none');
            document.getElementById('btnEditarCurso').classList.remove('d-none');
