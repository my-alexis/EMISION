                const badgeText = a.estado === 'ok' ? 'Generado' : a.estado === 'error' ? 'Error' : 'Pendiente';
                return `<tr id="manRow_${i}">
                    <td class="text-center">
                        <input type="checkbox" class="man-alumno-check form-check-input" data-idx="${i}">
