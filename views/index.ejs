        function manRenderTabla() {
            const tbody = document.getElementById('manTbodyAlumnos');
            const wrapper = document.getElementById('manTablaWrapper');
            const empty = document.getElementById('manEmptyMsg');

            if (manAlumnos.length === 0) {
                wrapper.classList.add('d-none');
                empty.style.display = '';
                document.getElementById('manContadorAlumnos').textContent = '0 alumnos';
