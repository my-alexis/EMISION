        function manAgregarAlumno() {
            const input = document.getElementById('manNuevoAlumno');
            const nombre = input.value.trim().toUpperCase();
            if (!nombre) { mostrarToast('Escribe el nombre del alumno', 'warning'); return; }
            if (manAlumnos.some(a => a.nombre === nombre)) { mostrarToast('Ese alumno ya está en la lista', 'warning'); return; }
            manAlumnos.push({ nombre, codigo: '', estado: 'pendiente' });
            manAlumnos.sort((a, b) => a.nombre.localeCompare(b.nombre));
            manRenumerarCodigos();
            manRenderTabla();
            input.value = '';
            input.focus();
        }

        function manEliminarAlumno(idx) {
            manAlumnos.splice(idx, 1);
            manRenumerarCodigos();
            manRenderTabla();
        }

        function manImportarLista() {
            const ta = document.getElementById('manListaMasiva');
            const lineas = ta.value.split('\n').map(l => l.trim().toUpperCase()).filter(l => l.length > 0);
            if (lineas.length === 0) { mostrarToast('La lista está vacía', 'warning'); return; }
            let agregados = 0;
            lineas.forEach(nombre => {
                if (!manAlumnos.some(a => a.nombre === nombre)) {
                    manAlumnos.push({ nombre, codigo: '', estado: 'pendiente' });
                    agregados++;
                }
            });
            manAlumnos.sort((a, b) => a.nombre.localeCompare(b.nombre));
            manRenumerarCodigos();
            manRenderTabla();
            ta.value = '';
            mostrarToast(`${agregados} alumno(s) importado(s) correctamente`, 'success');
        }

