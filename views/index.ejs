        // ── Generador de Sesiones ──────────────────────────
        const DIAS_ES = ['domingo', 'lunes', 'martes', 'miércoles', 'jueves', 'viernes', 'sábado'];
        const MESES_ES = ['enero', 'febrero', 'marzo', 'abril', 'mayo', 'junio', 'julio', 'agosto', 'septiembre', 'octubre', 'noviembre', 'diciembre'];

        function getSelectedDias() {
            return Array.from(document.querySelectorAll('#diasSemana .btn-check:checked'))
                .map(c => parseInt(c.value))
                .sort((a, b) => {
                    // Ordenar: lunes(1)..sábado(6)..domingo(0)
                    const order = [1, 2, 3, 4, 5, 6, 0];
                    return order.indexOf(a) - order.indexOf(b);
                });
        }

        function formatearHora(timeStr) {
            // timeStr = "19:30" → "19:30"
            return timeStr;
        }

        function generarSesiones() {
            const fechaStr = document.getElementById('sesionFechaInicio').value;
            const cantidad = parseInt(document.getElementById('sesionCantidad').value);
            const horaIni = document.getElementById('sesionHoraInicio').value;
            const horaFin = document.getElementById('sesionHoraFin').value;
            const dias = getSelectedDias();

            if (!fechaStr || !cantidad || dias.length === 0 || !horaIni || !horaFin) return [];

            const sesiones = [];
            const [y, m, d] = fechaStr.split('-').map(Number);
            let current = new Date(y, m - 1, d);
            let count = 0;

            // El bucle continuará hasta que hayamos encontrado la cantidad de sesiones solicitadas
            while (count < cantidad) {
                const dow = current.getDay(); // 0=dom, 1=lun...

                // 1. Verificamos si el día de la semana coincide con la frecuencia seleccionada
                if (dias.includes(dow)) {

                    // 2. ¡MODIFICACIÓN AQUÍ!: Verificamos si NO es feriado
                    if (!esFeriado(current)) {
                        sesiones.push(new Date(current));
                        count++;
                    }
                    // Si es feriado, el código simplemente ignora este día y no aumenta el contador 'count'
                }

                // Avanzamos al siguiente día calendario
                current.setDate(current.getDate() + 1);
            }

            return sesiones.map((fecha, i) => {
                const dia = DIAS_ES[fecha.getDay()];
                const numDia = fecha.getDate();
                const mes = MESES_ES[fecha.getMonth()];
                const anio = fecha.getFullYear();
                return `${i + 1}. ${dia}, ${numDia} de ${mes} de ${anio} ${horaIni} - ${horaFin}`;
            });
        }

        let _sesionesActuales = [];

        function previewSesiones() {
            _sesionesActuales = generarSesiones();
            const section = document.getElementById('sesionPreviewSection');
            const box = document.getElementById('sesionPreviewBox');

            if (_sesionesActuales.length === 0) {
                section.style.display = 'none';
                return;
            }

            section.style.display = 'block';
            box.innerHTML = 'Horarios de las sesiones (GMT - 5)<br>' +
                _sesionesActuales.map(s => `<div class="sesion-preview-item">${s}</div>`).join('');
        }

        function getSesionesTexto() {
            if (_sesionesActuales.length === 0) return '';
            return 'Horarios de las sesiones (GMT - 5)\r\n' + _sesionesActuales.join('\r\n');
        }

        function insertarSesionesEnDesc() {
            const texto = getSesionesTexto();
            if (!texto) { mostrarToast('Genera las sesiones primero', 'warning'); return; }
            const ta = document.getElementById('inputShortDesc');
            // Reemplazar bloque de sesiones si existe, o insertar al inicio
            const existente = ta.value;
            const regexSesiones = /Horarios de las sesiones[\s\S]*?(?=\r?\n\r?\n[A-Z]|$)/i;
            if (regexSesiones.test(existente)) {
                ta.value = existente.replace(regexSesiones, texto);
            } else {
                ta.value = texto + (existente ? '\r\n\r\n' + existente : '');
            }
            document.getElementById('statusDesc').textContent = 'Modificado';
            document.getElementById('statusDesc').className = 'badge bg-warning text-dark api-status-badge';
            mostrarToast('Sesiones insertadas en la descripción', 'success');
        }

        function copiarSesiones() {
            const texto = getSesionesTexto();
            if (!texto) { mostrarToast('Genera las sesiones primero', 'warning'); return; }
            navigator.clipboard.writeText(texto).then(() => mostrarToast('Texto copiado al portapapeles', 'success'));
        }

        const FERIADOS_PERU = [
            '01-01', // Año Nuevo
            '04-17', // Jueves Santo (Variable, ejemplo 2025/2026)
            '04-18', // Viernes Santo
            '05-01', // Día del Trabajo
            '06-07', // Batalla de Arica
            '06-29', // San Pedro y San Pablo
            '07-28', // Fiestas Patrias
            '07-29', // Fiestas Patrias
            '08-06', // Batalla de Junín
            '08-30', // Santa Rosa de Lima
            '10-08', // Combate de Angamos
