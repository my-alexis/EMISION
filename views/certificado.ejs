<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <style>
        /* Configuración de página */
        @page {
            size: A4 landscape;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #ffffff;
            color: #333;
        }

        .certificate {
            width: 297mm;
            height: 210mm;
            position: relative;
            box-sizing: border-box;
            /* SECCIÓN DEL FONDO ACTUALIZADA */
            background-image: url('<%= fondoSrc %>');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            overflow: hidden;
        }

        /* Contenido Central */
        .content {
            padding: 25px 80px;
            text-align: left;
            display: flex;
            flex-direction: column;
            position: relative;
            z-index: 2;
            /* Asegura que el texto esté sobre el fondo */
        }

        .logo-container {
            text-align: right;
            margin-bottom: 5px;
        }

        .logo-img {
            width: 200px;
        }

        h1.main-title {
            color: #0d47a1;
            font-size: 35px;
            margin: 0;
            font-weight: bold;
        }

        .text-info {
            font-size: 16px;
            margin: 2px 0 0 0;
            color: #444;
        }

        .student-name {
            color: #e67e22;
            /* Usamos un tamaño base de 42px, pero bajará hasta 28px si el contenedor es pequeño */
            font-size: clamp(18px, 4.5vw, 34px);
            font-weight: bold;
            margin: 1px 0;
            text-transform: uppercase;

            /* Permite hasta 2 líneas y corta con puntos suspensivos si es excesivo */
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;

            line-height: 1.2;
            /* Espacio entre las 2 filas */
            width: 100%;
            min-height: 1.2em;
            /* Mantiene espacio aunque sea 1 sola fila */
        }

        .course-name {
            color: #0d47a1;
            /* Un poco más pequeño que el nombre del alumno para jerarquía */
            font-size: clamp(18px, 4vw, 34px);
            font-weight: bold;
            margin: 1px 0;
            text-transform: uppercase;

            /* Permite 2 líneas */
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;

            line-height: 1.2;
            width: 100%;
        }

        .duration-info {
            font-size: 17px;
            margin-top: 1px;
            line-height: 1.3;
        }

        /* --- SECCIÓN DE FIRMAS --- */
        .footer-container {
            position: absolute;
            bottom: 55px;
            left: 80px;
            right: 80px;
            z-index: 2;
        }

        .footer {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            width: 100%;
        }

        .signature-box {
            width: 250px;
            text-align: center;
            border-top: 1px solid #e67e22;
            position: relative;
            padding-top: 5px;
        }

        .signature-img {
            position: absolute;
            bottom: 35px;
            /* Subido para no tapar la línea ni el nombre */
            left: 50%;
            transform: translateX(-50%);
            height: 85px;
            width: auto;
            z-index: 10;
            /* Truco para que el fondo blanco de JPG/PNG se vuelva transparente */
            mix-blend-mode: multiply;
        }

        .sig-label {
            font-size: 11px;
            color: #e67e22;
            font-weight: bold;
            text-transform: uppercase;
        }

        .sig-name {
            font-size: 14px;
            color: #333;
            font-weight: bold;
        }

        .cert-code {
            text-align: right;
        }

        .code-label {
            font-size: 11px;
            color: #0d47a1;
            font-weight: bold;
        }

        .code-value {
            font-size: 13px;
            font-weight: bold;
        }

        .location-date {
            margin-top: 15px;
            font-size: 13px;
            color: #666;
        }
    </style>
</head>

<body>
    <div class="certificate">
        <div class="top-bar">
            <div class="bar-navy"></div>
            <div class="bar-blue"></div>
            <div class="bar-orange"></div>
        </div>

        <div class="content">
            <br><br><br><br>
            <h1 class="main-title">CERTIFICADO</h1>
            <br>
            <div class="text-info">Otorgado a:</div>
            <br>
            <div class="student-name">
                <%= nombreAlumno %>
            </div>
            <br>
            <div class="text-info">Por haber aprobado satisfactoriamente el curso:</div><br>
            <div class="course-name">
                <%= nombreCurso %>
            </div>
            <br>

            <div class="duration-info">
                Con una duración de <strong>
                    <%= creditos %>
                </strong> horas <%= tipoHoras %><br>
                    Del <strong>
                        <%= inicio %>
                    </strong> al <strong>
                        <%= fin %>
                    </strong><br>
                    <strong>APROBADO</strong>
            </div>
        </div>

        <div class="footer-container">
            <div class="footer">

                <% if (firmaDocenteSrc && firmaDocenteSrc !=="" ) { %>
                    <div class="signature-box">
                        <img src="<%= firmaDocenteSrc %>" class="signature-img">
                        <div class="sig-label">Instructor</div>
                        <div class="sig-name">
                            <%= nombreDocente %>
                        </div>
                    </div>
                    <% } %>

                        <div class="signature-box">
                            <% if (firmaFijaSrc) { %>
                                <img src="<%= firmaFijaSrc %>" class="signature-img">
                                <% } %>
                                    <div class="sig-label">Coordinador de Operaciones</div>
                                    <div class="sig-name">JUAN ORTIZ</div>
                        </div>

                        <div class="cert-code">
                            <div class="code-label">CÓDIGO DE CERTIFICACIÓN</div>
                            <div class="code-value">
                                <%= codigoNH %>
                            </div>
                        </div>
            </div>
            <br>
            <div class="location-date">
                Lima, <%= fechaEmision %>
            </div>
        </div>
    </div>
</body>

</html>