        function manGetDatosBase() {
            const curso = document.getElementById('manCurso').value.trim();
            const docente = document.getElementById('manDocente').value.trim().toUpperCase();
            const tipoHoras = document.querySelector('input[name="manTipoHoras"]:checked').value;
            const horasAcad = document.getElementById('manHorasAcad').value || '0';
            const horasCron = document.getElementById('manHorasCron').value || '0';
            const creditos = tipoHoras === 'academicas' ? horasAcad : horasCron;
            const tipo = document.querySelector('input[name="manTipoDoc"]:checked').value;
            const incluirQR = document.getElementById('manCheckQR').checked;
            const fechaEmision = manFechaISO_a_Texto(document.getElementById('manFechaEmision').value);
            const inicio = manFechaISO_a_Texto(document.getElementById('manFechaInicio').value);
            const fin = manFechaISO_a_Texto(document.getElementById('manFechaFin').value);

            if (!curso) { mostrarToast('Escribe el nombre del curso', 'warning'); return null; }
            if (!docente) { mostrarToast('Escribe el nombre del docente', 'warning'); return null; }

            return { curso, docente, creditos, tipoHoras, inicio, fin, tipo, incluirQR, fechaEmision };
        }

        async function manGetFirmaBase64() {
            const incluirFirma = document.getElementById('manSwitchFirma').checked;
            const tipo = document.querySelector('input[name="manTipoDoc"]:checked').value;
            if (!incluirFirma || tipo === 'constancia') return '';
            const file = document.getElementById('manInputFirma').files[0];
            if (!file) return '';
            return new Promise(resolve => {
                const r = new FileReader();
                r.onload = e => resolve(e.target.result);
                r.readAsDataURL(file);
            });
        }

        async function manDescargarUno(idx) {
            const base = manGetDatosBase();
            if (!base) return;
            const alumno = manAlumnos[idx];
            const firmaManual = await manGetFirmaBase64();
            const endpoint = base.tipo === 'constancia'
                ? '/api/generar-pdf-individual-constancia'
                : '/api/generar-pdf-individual';

            manAlumnos[idx].estado = 'procesando';
            manRenderTabla();

            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        nombre: alumno.nombre,
                        codigo: alumno.codigo,
                        curso: base.curso,
                        docente: base.docente,
                        inicio: base.inicio,
                        fin: base.fin,
                        creditos: base.creditos,
                        tipoHoras: base.tipoHoras,
                        firmaManual,
                        incluirQR: base.incluirQR,
                        fechaEmision: base.fechaEmision,
                        temarioPDF: MAN_TEMARIO_BASE64 || null
                    })
                });
                if (!res.ok) throw new Error(await res.text());
                const blob = await res.blob();
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                const prefijo = base.tipo === 'constancia' ? 'Constancia' : 'Certificado';
                a.download = `${prefijo}_${alumno.nombre.replace(/\s+/g, '_')}_${alumno.codigo}.pdf`;
                a.click();
                URL.revokeObjectURL(url);
                manAlumnos[idx].estado = 'ok';
            } catch (e) {
                manAlumnos[idx].estado = 'error';
                mostrarToast('Error al generar: ' + e.message, 'danger');
            }
            manRenderTabla();
        }

        async function manCertificarSeleccionados() {
            const base = manGetDatosBase();
            if (!base) return;
            const checks = Array.from(document.querySelectorAll('.man-alumno-check:checked'));
            if (checks.length === 0) { mostrarToast('Selecciona al menos un alumno', 'warning'); return; }
            const firmaManual = await manGetFirmaBase64();
            const seleccionados = checks.map(c => manAlumnos[parseInt(c.dataset.idx)]);

            mostrarToast(`Generando ${seleccionados.length} documento(s)...`, 'info');

            for (const alumno of seleccionados) {
                const idx = manAlumnos.indexOf(alumno);
                const endpoint = base.tipo === 'constancia'
                    ? '/api/generar-pdf-individual-constancia'
                    : '/api/generar-pdf-individual';
                manAlumnos[idx].estado = 'procesando';
                manRenderTabla();
                try {
                    const res = await fetch(endpoint, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            nombre: alumno.nombre,
                            codigo: alumno.codigo,
                            curso: base.curso,
                            docente: base.docente,
                            inicio: base.inicio,
                            fin: base.fin,
                            creditos: base.creditos,
                            tipoHoras: base.tipoHoras,
                            firmaManual,
                            incluirQR: base.incluirQR,
                            fechaEmision: base.fechaEmision,
                            temarioPDF: MAN_TEMARIO_BASE64 || null
                        })
                    });
                    if (!res.ok) throw new Error(await res.text());
                    const blob = await res.blob();
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    const prefijo = base.tipo === 'constancia' ? 'Constancia' : 'Certificado';
                    a.download = `${prefijo}_${alumno.nombre.replace(/\s+/g, '_')}_${alumno.codigo}.pdf`;
                    a.click();
                    URL.revokeObjectURL(url);
                    manAlumnos[idx].estado = 'ok';
                } catch (e) {
                    manAlumnos[idx].estado = 'error';
                    mostrarToast(`Error con ${alumno.nombre}: ` + e.message, 'danger');
                }
                manRenderTabla();
                await new Promise(r => setTimeout(r, 400)); // pausa entre PDFs para no saturar el browser
            }
            mostrarToast('¡Proceso completado!', 'success');
        }
    </script>
</body>

</html>
