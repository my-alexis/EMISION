        function esFeriado(fecha) {
            const diaMes = (fecha.getMonth() + 1).toString().padStart(2, '0') + '-' +
                fecha.getDate().toString().padStart(2, '0');
            return FERIADOS_PERU.includes(diaMes);
        }

